{
    "name": "techverse-quiz-arena",
    "productName": "TechVerse Quiz Arena",
    "version": "1.0.6",
    "description": "Professional Dual-Screen Quiz Competition Software",
    "main": "out/main/index.js",
    "author": "Antigravity <support@techverse.com>",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "pack": "electron-builder --dir",
        "dist": "electron-builder",
        "prepare": "husky",
        "version:bump": "node scripts/version-bump.js"
    },
    "build": {
        "appId": "com.techverse.quizarena",
        "productName": "TechVerse Quiz Arena",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "resources/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "runAfterFinish": true
        },
        "files": [
            "out/**/*",
            "data/**/*",
            "resources/**/*"
        ]
    },
    "dependencies": {
        "canvas-confetti": "^1.9.2",
        "clsx": "^2.1.0",
        "howler": "^2.2.4",
        "katex": "^0.16.10",
        "lucide-react": "^0.363.0",
        "recharts": "^2.12.3",
        "tailwind-merge": "^2.2.2",
        "zustand": "^4.5.2"
    },
    "devDependencies": {
        "@electron-toolkit/preload": "^3.0.0",
        "@electron-toolkit/utils": "^3.0.0",
        "@types/canvas-confetti": "^1.9.0",
        "@types/howler": "^2.2.12",
        "@types/react": "^18.2.66",
        "@types/react-dom": "^18.2.22",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.18",
        "electron": "^29.1.5",
        "electron-builder": "^24.13.3",
        "electron-vite": "^2.1.0",
        "framer-motion": "^12.38.0",
        "husky": "^9.1.7",
        "postcss": "^8.4.35",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.4.2",
        "vite": "^5.1.4"
    }
}
